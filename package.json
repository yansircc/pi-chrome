{
  "name": "pi-chrome",
  "version": "0.16.0",
  "description": "Let Pi use your existing signed-in Chrome profile after explicit authorization.",
  "keywords": [
    "agent",
    "agentic",
    "ai-agent",
    "authenticated-session",
    "automation-tools",
    "browser",
    "browser-automation",
    "browser-control",
    "browser-use",
    "cdp-alternative",
    "chrome",
    "chrome-extension",
    "llm-agent",
    "llm-tools",
    "pi",
    "pi-agent",
    "pi-extension",
    "pi-package",
    "playwright-alternative",
    "puppeteer-alternative",
    "real-profile",
    "screenshot",
    "selenium-alternative",
    "stagehand-alternative",
    "web-automation",
    "web-debugging",
    "web-scraping"
  ],
  "homepage": "https://github.com/yansircc/pi-chrome#readme",
  "bugs": {
    "url": "https://github.com/yansircc/pi-chrome/issues"
  },
  "license": "MIT",
  "author": "yansircc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yansircc/pi-chrome.git"
  },
  "workspaces": {
    "catalog": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
      "vitest": "4.1.10",
      "vite-plus": "0.2.4"
    }
  },
  "files": [
    "dist/browser-extension",
    "dist/pi",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/prepare-effect-tsgo.mjs",
    "prepack": "vp run build",
    "prepublishOnly": "vp run release"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@effect/platform-node": "4.0.0-beta.97",
    "@effect/tsgo": "0.21.0",
    "@effect/vitest": "4.0.0-beta.97",
    "@types/chrome": "0.1.36",
    "@types/node": "22.20.1",
    "effect": "4.0.0-beta.97",
    "es-module-lexer": "2.3.1",
    "knip": "6.26.0",
    "typescript": "7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.19.0 || >=24.11.0"
  },
  "packageManager": "pnpm@10.11.0",
  "pi": {
    "extensions": [
      "./dist/pi/extension.js"
    ]
  }
}
